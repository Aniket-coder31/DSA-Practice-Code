import java.util.*;

public class a{

    public static int maxsum(int arr[],int key){
        int sum=0;
        for(int i=0;i<key;i++){
            sum+=arr[i];
        }
        int maxsum=sum;
        int left=0;
        int right=key-1;
        while(right<arr.length-1){
            sum-=arr[left];
            left++;
            right++;
            sum+=arr[right];
            if(maxsum<sum) maxsum=sum;
        }

        return maxsum;
    }

    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        System.out.print("What is the size of your array? ");
        int size=sc.nextInt();
        int nums[]=new int[size];
        System.out.print("Enter the numbers - ");
        for(int i=0;i<size;i++){
            nums[i]=sc.nextInt();
        }
        System.out.println("what is the size of a subarray? ");
        int subsize=sc.nextInt();
        sc.close();
        System.out.println("The maximum sum is "+maxsum(nums, subsize));
    }
}
